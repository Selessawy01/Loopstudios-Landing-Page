
@use "variables";

*, *::after, *::before {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}
html, body {
    overflow-x: hidden;
}
img {   
    display: block;
    max-width: 100%;  
}

body {
    margin:0;
}

.hero {
    background-image: url('../images/mobile/image-hero.jpg');
    background-size: cover;
    background-position: center;
    height: 650px; /* temporary test */
}

.hero__border { padding : 40px 24px; }

.hero__main {
    display:flex;
    justify-content: space-between;
    height:clamp(24px,5vw,32px);
    /*height:16px;*/
}


/*.hero__mob-nav*/
nav {
    max-width: 48rem;
    background-color: black;
    height:100vh;
    width:100%;
    margin-inline: auto;
   /* padding-top:clamp(40px,8.5vw,64px);*/
    padding-top:clamp(variables.$spacing-500,8.5vw,variables.$spacing-800);
    padding-left: clamp(24px,10.5vw,80px);
    padding-right: clamp(24px,10.5vw,80px);
    position: fixed;
    top:0;
    right:0;
    display:flex;
    flex-direction: column;
    transition: right 0.3s ease-in-out;
    z-index:100;
}
.hero__menu-button,close-menu{
    background: none;
    border:none;
    padding: 0;
    cursor: pointer;
}
.mob-nav-header{
    display:flex;
    justify-content: space-between;
    height:1.5rem;
    margin-bottom: 160px;
}

.logo-img,
.close-img {
    height:clamp(1.125rem,5vw,1.5rem);
}
