@media (min-width: 48rem) { // tablet breakpoint
  footer {
    display: grid;
    grid-template-columns: 1fr 1fr; // two columns
    grid-template-rows: auto auto; // two rows
    width: 80%;
    margin-inline: auto;
    gap: v.$spacing-400;

    &__logo {
      grid-column: 1 / 2; // first column
      justify-self: start; // left
    }

    &__social-links {
      grid-column: 2 / 3; // second column
      justify-self: end; // right
    }

    &__nav {
      grid-column: 1 / 2;
      justify-self: start;
    }

    &__copyright {
      grid-column: 2 / 3;
      justify-self: end;
    }
  }
}
