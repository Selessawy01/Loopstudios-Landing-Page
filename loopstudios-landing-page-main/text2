.nav__link-name {
    color:white;
    text-decoration: none;
}

/*----- Hero Title -----*/
.hero__title-borders{
    margin-top: 163px;
    display:flex;
    align-items: center;
    justify-content: center;
   
    padding:clamp(16px,4.28vw,40px) clamp(24px,6vw,40px);
    /*padding:clamp(variables.$spacing-200,4.28,variables.$spacing-500)  clamp(variables.$spacing-300,6vw,variables.$spacing-500);*/
    border: 1px solid variables.$white;
}

.hero__title{
    text-transform: uppercase;
    color: variables.$white;
    font-family: variables.$font-family-Josefin ;
    font-size:clamp(40px,9.5vw,70px);
    line-height: 100%;
    letter-spacing: 0;
    font-weight: variables.$fw-300;
}

.hidden {
    display:none;
}
/*======= Tablet View =======*/
@media (min-width:768px){
 
.hero__border{ 
    padding-top :64px;
    padding-left:80px ;
    padding-right: 80px;
    
}
.hero__title-borders { margin-top: 126px;}

}

/*======= Desktop View =======*/
@media (min-width:1024px){

.hero__border{ 
    
    padding-left:165px ;
    padding-right: 165px;
    
}
.hero__title-borders { width:49.6%;} 

}




.footer {
  background-color: v.$black;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  gap: v.$spacing-500;
  padding-block: v.$spacing-600;

  &__logo {
    height: 24px; // adjust as needed
    margin-bottom: v.$spacing-400;
  }

  &__nav {
    width: 100%;
    display: flex;
    justify-content: center;

    &-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: v.$spacing-300;
      padding: 0;
      margin: 0;

      @media(min-width: 48rem) {
        flex-direction: row;
        gap: v.$spacing-400;
      }
    }
  }

  &__social-links {
    display: flex;
    gap: v.$spacing-200;
    margin-top: v.$spacing-400;
  }

  &__copyright {
    color: v.$white;
    font-size: 0.875rem; // 14px
    line-height: 165%;
    font-weight: v.$fw-regular;
    text-align: center;
    margin-top: v.$spacing-300;
  }
}




&__nav-list {
  list-style: none;
  display: flex;
  flex-direction: column;
  align-items: center; // center mobile
  gap: v.$spacing-300;
  padding: 0;
  margin: 0;

  @media (min-width: 48rem) {
    flex-direction: row;
    justify-content: center; // center desktop
    gap: v.$spacing-400;
  }
}















